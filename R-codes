    data = combined
  )
  
  coef <- summary(model)$coefficients
  
  data.frame(
    Cytokine = cyto,
    Estimate = coef["scale(log_MDV)", "Estimate"],
    SE = coef["scale(log_MDV)", "Std. Error"],
    p_value = coef["scale(log_MDV)", "Pr(>|t|)"]
  )
}) %>% bind_rows()

