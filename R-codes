library(rstatix)

cytokines <- c("IFNG","IL2","IL4","IL6","IL10","IL17")

cyto_long <- combined %>%
  pivot_longer(cols = all_of(cytokines),
               names_to = "Cytokine",
               values_to = "Expression")

# Factor order
cyto_long$Stage <- factor(cyto_long$Stage,
                          levels = c("Control","Latent","Clinical"))

# ---- PAIRWISE TESTS (CORRECT WAY) ----
stat_results <- cyto_long %>%
  group_by(Tissue, Cytokine) %>%
  pairwise_wilcox_test(Expression ~ Stage,
                       p.adjust.method = "BH") %>%
  ungroup()

# ---- ADD y.position ----
y_pos <- cyto_long %>%
  group_by(Tissue, Cytokine) %>%
  summarise(max_val = max(Expression, na.rm = TRUE), .groups = "drop")

stat_results <- stat_results %>%
  left_join(y_pos, by = c("Tissue","Cytokine")) %>%
  group_by(Tissue, Cytokine) %>%
  mutate(
    y.position = max_val * (1.2 + 0.15 * row_number()),
    label = p.adj.signif
  ) %>%
  ungroup()

# ---- IMPORTANT: REMOVE DUPLICATES ----
stat_results <- stat_results %>%
  distinct(Tissue, Cytokine, group1, group2, .keep_all = TRUE)

# ---- PLOT ----
fig2 <- ggboxplot(cyto_long,
                  x = "Stage", y = "Expression",
                  color = "Stage",
                  add = "jitter",
                  palette = c("#4CAF50","#2196F3","#F44336")) +
  
  facet_grid(Tissue ~ Cytokine, scales = "free_y") +
  
  stat_pvalue_manual(stat_results,
                     label = "label",
                     tip.length = 0.01,
                     size = 3,
                     hide.ns = TRUE) +
  
  theme_classic(base_size = 12) +
  theme(
    axis.text.x = element_text(angle = 30, hjust = 1),
    strip.text = element_text(size = 10)
  )

