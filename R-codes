library(tidyverse)
library(readxl)
library(ggpubr)
library(lme4)
library(lmerTest)
library(emmeans)

##############################################
# 1. LOAD DATA
##############################################
liver  <- read_excel("20260413_Liver MDV data compiled.xlsx")
spleen <- read_excel("20260413_Spleen MDV data compiled.xlsx")

liver  <- liver  %>% rename(SampleName = 1)
spleen <- spleen %>% rename(SampleName = 1)

##############################################
# 2. HELPER: MEAN OF REPLICATES
##############################################
row_mean <- function(df, prefix){
  cols <- grep(paste0("^", prefix), names(df), value = TRUE)
  rowMeans(df[, cols], na.rm = TRUE)
}

##############################################
# 3. CREATE SAMPLE-LEVEL DATA (CRITICAL)
##############################################
prepare <- function(df, tissue){
  df %>%
    mutate(
      Tissue = tissue,
      Group = ifelse(grepl("^N-", SampleName), "Control", "Affected"),
      MDV  = row_mean(., "MDV_"),
      IFNG = row_mean(., "IFNG_"),
      IL2  = row_mean(., "IL2_"),
      IL4  = row_mean(., "IL4_"),
      IL6  = row_mean(., "IL6_"),
      IL10 = row_mean(., "IL10_"),
      IL17 = row_mean(., "IL17_")
    ) %>%
    select(SampleName, Tissue, Group, MDV, IFNG, IL2, IL4, IL6, IL10, IL17)
}

liver_p  <- prepare(liver,  "Liver")
spleen_p <- prepare(spleen, "Spleen")

combined <- bind_rows(liver_p, spleen_p)

##############################################
# 4. DEFINE STAGE (BASED ON LIVER ONLY)
##############################################
liver_stage <- liver_p %>%
  mutate(Stage = case_when(
    Group == "Control" ~ "Control",
    MDV < 2000 ~ "Latent",
    TRUE ~ "Clinical"
  )) %>%
  select(SampleName, Stage)

combined <- combined %>%
  left_join(liver_stage, by = "SampleName")

table(combined$Stage)   # sanity check

##############################################
# 5. LOG TRANSFORM MDV (HANDLE VARIATION)
##############################################
combined <- combined %>%
  mutate(log_MDV = log10(MDV + 1))

##############################################
# 6. MDV COMPARISON (LIVER vs SPLEEN)
##############################################
mdv_wide <- combined %>%
  select(SampleName, Tissue, log_MDV) %>%
  pivot_wider(names_from = Tissue, values_from = log_MDV)

# Paired test
wilcox.test(mdv_wide$Liver, mdv_wide$Spleen, paired = TRUE)

# Plot
ggpaired(mdv_wide, cond1 = "Liver", cond2 = "Spleen",
         ylab = "Log10 MDV Load") +
  theme_bw()

##############################################
# 7. BAR PLOTS (MEAN ± SEM)
##############################################
cytokines <- c("IFNG","IL2","IL4","IL6","IL10","IL17")

plot_bar <- function(df, marker){
  
  df %>%
    group_by(Tissue, Stage) %>%
    summarise(
      mean = mean(.data[[marker]], na.rm = TRUE),
      sem  = sd(.data[[marker]], na.rm = TRUE)/sqrt(n()),
      .groups = "drop"
    ) %>%
    
    ggplot(aes(x = Stage, y = mean, fill = Stage)) +
    geom_bar(stat = "identity", position = "dodge") +
    geom_errorbar(aes(ymin = mean - sem, ymax = mean + sem),
                  width = 0.2) +
    facet_wrap(~Tissue, scales = "free_y") +
    ggtitle(marker) +
    theme_bw()
}

# Example plots
plot_bar(combined, "IL10")
plot_bar(combined, "IL6")

##############################################
# 8. CYTOKINE DIFFERENCE BY GROUP
##############################################
cyto_long <- combined %>%
  pivot_longer(cols = all_of(cytokines),
               names_to = "Cytokine",
               values_to = "Expression")

ggboxplot(cyto_long, x = "Stage", y = "Expression",
          color = "Stage", add = "jitter") +
  facet_grid(Tissue ~ Cytokine, scales = "free_y") +
  theme_bw()

##############################################
# 9. SCATTER: CYTOKINE vs VIRAL LOAD
##############################################
plot_scatter <- function(marker){
  
  ggscatter(combined,
            x = "log_MDV",
            y = marker,
            color = "Tissue",
            add = "reg.line") +
    stat_cor(method = "spearman") +
    ggtitle(paste(marker, "vs Viral Load")) +
    theme_bw()
}

plot_scatter("IL10")
plot_scatter("IL6")
plot_scatter("IFNG")
plot_scatter("IL2")
plot_scatter("IL4")
plot_scatter("IL17")
##############################################
# 10. MIXED MODEL (ROBUST ANALYSIS)
##############################################
models <- lapply(cytokines, function(cyto){
  
  model <- lmer(
    as.formula(paste0(cyto, " ~ scale(log_MDV) + Tissue + (1|SampleName)")),
    data = combined
  )
  
  summary(model)
})

##############################################
# 11. KEY MARKER MODEL
##############################################
full_model <- lmer(
  scale(log_MDV) ~ IFNG + IL2 + IL4 + IL6 + IL10 + IL17 +
    Tissue + (1|SampleName),
  data = combined
)

summary(full_model)

